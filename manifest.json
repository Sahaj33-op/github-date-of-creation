{
  "name": "Github - Date of creation",
  "version": "3.0.0",
  "manifest_version": 3,
  "description": "Display a date of creation of a repository hosted on Github",
  "homepage_url": "https://github.com/Sahaj33-op/github-date-of-creation.git",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "author": "Varayut Lerdkanlayanawat",
  "action": {
    "default_icon": "icons/icon19.png"
  },
  "permissions": [
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "https://*.github.com/*",
    "https://api.github.com/*"
  ],
  "background": {
    "service_worker": "src/bg/index.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.github.com/*"
      ],
      "js": [
        "src/constant/index.js",
        "src/formatters/index.js",
        "src/inject/index.js"
      ]
    }
  ],
  "options_ui": {
    "page": "src/option/index.html"
  }
}
